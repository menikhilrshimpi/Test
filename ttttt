/* Fix radio button + label alignment */
.formTable > tbody > tr > td:nth-child(2) > table td {
  display: inline-flex !important;
  align-items: center !important;
  gap: 4px !important;
  vertical-align: middle !important;
  white-space: nowrap !important;
  padding: 0 8px 0 0 !important;
}

.formTable > tbody > tr > td:nth-child(2) > table input[type="radio"] {
  width: auto !important;
  display: inline-block !important;
  margin: 0 !important;
  padding: 0 !important;
  position: static !important; /* remove your top:-1px */
  flex-shrink: 0;
}

.formTable > tbody > tr > td:nth-child(2) > table label {
  display: inline !important;
  margin: 0 !important;
  padding: 0 !important;
  vertical-align: middle !important;
  cursor: pointer;
  line-height: 1 !important;
}

/* Reset the nested table itself */
.formTable > tbody > tr > td:nth-child(2) > table {
  width: auto !important;
  table-layout: auto !important;
  border-collapse: collapse;
}

.formTable > tbody > tr > td:nth-child(2) > table tr,
.formTable > tbody > tr > td:nth-child(2) > table tbody {
  display: inline-flex !important;
  align-items: center !important;
  flex-wrap: wrap;
  gap: 8px;
}








.formTable > tbody > tr > td,
.formTable > tbody > tr > th {
  padding-top: 12px !important;
  padding-bottom: 12px !important;
  padding-left: 8px !important;
  padding-right: 8px !important;
  vertical-align: middle !important;
}

/* Prevent double padding inside radio table */
.formTable > tbody > tr > td:nth-child(2) > table td {
  padding-top: 0 !important;
  padding-bottom: 0 !important;
}


/* Equal row spacing across all tables */
.formTable > tbody > tr > td,
.formTable > tbody > tr > th {
  padding: 10px 8px !important;
  vertical-align: middle !important;
}

/* Column 3 button vertical alignment */
.formTable > tbody > tr > td:nth-child(3),
.formTable > tbody > tr > th:nth-child(3) {
  vertical-align: middle !important;
  padding-left: 10px !important;
}

/* Validate buttons inside column 3 */
.formTable > tbody > tr > td:nth-child(3) input[type="submit"],
.formTable > tbody > tr > td:nth-child(3) input[type="button"] {
  vertical-align: middle !important;
  margin: 0 !important;
}